# ── Broker ────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Notion ────────────────────────────────────────
NOTION_TOKEN=
NOTION_DB_ID=

# ── Pinecone ──────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=bottrading

# ── Myfxbook (login con cuenta gratuita) ──────────
# Crea cuenta gratis en https://www.myfxbook.com/register
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# ── Configuración del bot ─────────────────────────
TRADING_SYMBOL=EURUSD
LOOP_INTERVAL_SECONDS=60
CANDLES_HISTORY=50
# (LOT_SIZE eliminado: el lote se calcula dinámicamente en CapitalGuard
#  a partir del capital_activo, riesgo de fase, SL y pip_value del par.)

# CAPITAL_TRABAJO: techo de capital sobre el que opera el bot.
# Útil para simular cuenta pequeña en demo grande (ej: balance demo $50000
# pero quieres operar contra $50). Si la cuenta real tiene menos balance,
# se usa el balance real. Default: 50.
CAPITAL_TRABAJO=50

# ── Logging ───────────────────────────────────────
# Nivel mínimo: DEBUG, INFO, WARNING, ERROR. Default INFO.
LOG_LEVEL=INFO
# Si está vacío, no escribe a archivo. Si tiene ruta, rota cada 5MB con 5 backups.
# Ejemplo: LOG_FILE=logs/bot.log
LOG_FILE=